{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-native",
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true
  },
  "include": [
    "App.js",
    "index.js",
    "src/**/*.js"
  ],
  "exclude": [
    "node_modules",
    "android",
    "ios"
  ]
}
