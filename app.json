{
  "expo": {
    "name": "LaterLens",
    "slug": "LaterLens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.shubhamksharma.laterlens"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.shubhamksharma.laterlens"
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.png",
          "color": "#534AB7",
          "sounds": [],
          "mode": "production"
        }
      ],
      [
        "expo-media-library",
        {
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-location",
      "@react-native-community/datetimepicker",
      "expo-video"
    ]
  }
}
